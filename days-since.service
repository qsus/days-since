[Unit]
Description=Days since MFF
After=network.target

[Service]
User=www-data
Group=www-data
RuntimeDirectory=days-since
WorkingDirectory=/root/days-since
ExecStart=/usr/bin/gunicorn -w 4 app:app --bind unix:/run/days-since/flask.sock

# Automatically restart the app if it crashes
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target

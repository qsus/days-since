[Unit]
Description=Days since MFF
After=network.target

[Service]
User=www-data
Group=www-data

WorkingDirectory=/root/days-since
ExecStart=/usr/bin/gunicorn -w 4 app:app -b 127.0.0.1:8000

# Automatically restart the app if it crashes
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
